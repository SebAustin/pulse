# ─────────────────────────────────────────────────────────────────────────────
# Pulse environment contract.  Copy to `.env.local` for local dev.
# NEVER commit real credentials. Production uses Vercel OIDC (no stored keys).
# ─────────────────────────────────────────────────────────────────────────────

# Which DynamoDB the app talks to: "local" (DynamoDB Local via Docker) or "aws".
PULSE_DB_MODE=local

# DynamoDB table name (same in local and prod).
PULSE_TABLE_NAME=Pulse

# AWS region. Pinned explicitly — do NOT rely on Vercel's auto-set AWS_REGION,
# which follows the function's execution region.
AWS_REGION=us-east-1

# ── Local mode only (PULSE_DB_MODE=local) ───────────────────────────────────
# DynamoDB Local endpoint. Dummy credentials are used automatically in local mode.
DYNAMODB_LOCAL_ENDPOINT=http://localhost:8000

# ── AWS mode on Vercel (PULSE_DB_MODE=aws) ──────────────────────────────────
# IAM role assumed via Vercel OIDC (AssumeRoleWithWebIdentity). No access keys.
# Set in the Vercel dashboard after running scripts/init-aws.sh.
AWS_ROLE_ARN=

# ── AWS mode for LOCAL testing against real AWS (optional fallback only) ─────
# Prefer OIDC. These are a last-resort for running against real AWS off-Vercel.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Real-time tuning ────────────────────────────────────────────────────────
SSE_INTERVAL_MS=1000
SSE_CACHE_TTL_MS=500

# ── Participant session signing (F-02 / SC-identity) ────────────────────────
# Secret for HMAC-signing participant identity cookies (`pulse_pt_<eventId>`).
# In development, a fixed default is used automatically — no setup required.
# PRODUCTION MUST set this to a strong random value:
#   openssl rand -base64 32
# Without this set in production, participant cookies are signed with a
# predictable value that is insecure.
PULSE_SESSION_SECRET=

# ── Optional AI assist (stretch). Feature hides itself when unset. ───────────
# OpenAI API key for poll-suggestion + word-cloud-sentiment assist. Server-side only.
OPENAI_API_KEY=
# OpenAI model (default gpt-4o-mini — cheap + capable). e.g. gpt-4o, gpt-4.1-mini
OPENAI_MODEL=gpt-4o-mini

# ── Data lifecycle ──────────────────────────────────────────────────────────
# Days durable items (events, counters, leaderboard, vote dedup) are retained.
JUDGING_WINDOW_DAYS=30
# Ephemeral reaction item TTL in seconds.
REACTION_TTL_SEC=600
# Presence CONN# item TTL in seconds (refreshed each SSE heartbeat tick).
PRESENCE_TTL_SEC=15
# OPS#WRITES# item TTL in seconds (rolling window for write-rate readout).
OPS_WRITES_TTL_SEC=60
# OPS rolling window size in seconds.
OPS_WINDOW_SEC=5

# ── Sharding ─────────────────────────────────────────────────────────────────
# Counter shards per option (min 10). Increase for higher write throughput.
SHARD_COUNT=10
