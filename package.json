{
  "name": "pulse",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "e2e": "playwright test",
    "ddb:up": "docker compose up -d",
    "ddb:down": "docker compose down",
    "ddb:init": "tsx scripts/init-local-table.ts",
    "seed": "tsx scripts/seed.ts",
    "loadtest": "tsx scripts/loadtest.ts",
    "latency-probe": "tsx scripts/latency-probe.ts",
    "dev:local": "npm run ddb:up && npm run ddb:init && npm run dev",
    "cdk:synth": "cd infra && cdk synth",
    "deploy:init-aws": "bash scripts/init-aws.sh",
    "deploy:infra": "bash scripts/deploy-infra.sh",
    "destroy:infra": "bash scripts/destroy-infra.sh"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws-sdk/util-dynamodb": "^3.700.0",
    "@vercel/oidc-aws-credentials-provider": "^3.1.5",
    "nanoid": "^5.0.9",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^2.1.8",
    "aws-cdk": "^2.173.4",
    "aws-cdk-lib": "^2.173.4",
    "constructs": "^10.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
